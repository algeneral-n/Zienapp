# ============================================================================
# ZIEN Platform - Environment Variables
# Copy to .env and fill in values. See docs/architecture/infrastructure.md
# ============================================================================

# ─── Supabase (PUBLIC - safe for client bundle via VITE_ prefix) ───────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Cloudflare Turnstile (PUBLIC) ─────────────────────────────────────────
VITE_TURNSTILE_SITE_KEY=

# ─── API Gateway (Cloudflare Worker) ──────────────────────────────────────
VITE_API_URL=

# ─── App Metadata ─────────────────────────────────────────────────────────
VITE_APP_NAME=ZIEN
VITE_APP_VERSION=1.0.0

# ─── SECRET keys (NEVER prefix with VITE_ - Worker secrets via wrangler secret put) ─
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# GOOGLE_API_KEY=          (Gemini AI)
# OPENAI_API_KEY=
# TURNSTILE_SECRET_KEY=

# ─── Payment providers (set in Worker secrets if using) ───────────────
# NI_API_URL=              (Network International)
# NI_API_KEY=
# NI_OUTLET_REF=
# TILR_API_URL=            (Tilr)
# TILR_API_KEY=
# TILR_MERCHANT_ID=

# ─── Communication providers (set in Worker secrets if using) ─────────
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_APPLICATION_ID=
# VONAGE_PRIVATE_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# ─── AI providers (set in Worker secrets if using) ────────────────────
# ELEVENLABS_API_KEY=      (Text-to-Speech)

# ─── Apple Pay (set in Worker secrets if using) ──────────────────────
# APPLE_PAY_MERCHANT_ID=
# APPLE_PAY_LATER_TOKEN=

cloudflare_page_subdomain=www.zien-ai.app
page_name=zien
cloudflare_worker_subdomain=api.plt.zien-ai.app
worker_name=zien-api
